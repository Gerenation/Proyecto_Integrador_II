# -----------------------------------------------------------------------------
# VARIABLES DE ENTORNO DEL BACKEND (SIVUR)
# -----------------------------------------------------------------------------
# Copia este archivo como ".env" en la carpeta backend/ y rellena valores.
#
# Node expone `process.env` con pares clave=valor. `dotenv` lee .env al arrancar
# y vuelca cada línea en process.env. No subas .env a Git.
# -----------------------------------------------------------------------------

# Ollama (IA local). Por defecto: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Modelo instalado en Ollama (ver: ollama list). Ej.: llama3, llama3.2, mistral
OLLAMA_MODEL=llama3

# Opcional: milisegundos máximos esperando respuesta (default 120000)
# OLLAMA_TIMEOUT_MS=120000

# Opcional: desactivar format=json en la API (si el modelo devuelve vacío, prueba OLLAMA_JSON_FORMAT=false)
# OLLAMA_JSON_FORMAT=false

# Puerto HTTP (debe coincidir con el proxy del frontend si lo usas)
PORT=5001

# MongoDB y JWT
# MONGODB_URI=mongodb://127.0.0.1:27017/tu_bd
# JWT_SECRET=una_cadena_larga_y_secreta

# Correo (nodemailer) — confirmación de reportes. Sin esto, el backend solo registra en log.
# Ejemplo Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=tu@gmail.com SMTP_PASS=app_password
# SMTP_FROM="SIVUR <tu@gmail.com>"
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
