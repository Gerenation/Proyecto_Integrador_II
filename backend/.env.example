PORT=5001

# Opcional: URI de MongoDB.
# Si NO defines MONGODB_URI, la app usará automáticamente:
#   mongodb://127.0.0.1:27017/sivu_<tu_usuario_windows_normalizado>
# Ejemplo: para el usuario "danie" -> sivu_danie, para "juan-pc" -> sivu_juanpc
# Esto evita que las BDs de distintos usuarios se pisen entre sí.
# Descomenta y personaliza solo si quieres forzar un nombre de BD concreto.
# MONGODB_URI=mongodb://localhost:27017/sivu_tuusuario

JWT_SECRET=tu_secreto_super_seguro_aqui_cambiar_en_produccion
